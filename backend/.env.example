PORT=3001

# --- Interakt Configuration ---
# Get this key from the Interakt Dashboard -> Developer Settings (Base64 encoded string)
INTERAKT_API_KEY=your_interakt_base64_api_key_here

# --- Meta WhatsApp Cloud API Configuration (Production) ---
# Get these from the Meta App Dashboard
META_ACCESS_TOKEN=your_meta_permanent_access_token_here
META_PHONE_NUMBER_ID=your_meta_phone_number_id_here
WEBHOOK_VERIFY_TOKEN=your_custom_webhook_verify_token_here

# --- Meta WhatsApp Cloud API Configuration (Sandbox / Test Mode) ---
# Test credentials provided by Meta upon App creation
TEST_META_ACCESS_TOKEN=your_meta_temporary_test_token_here
TEST_META_PHONE_NUMBER_ID=your_meta_test_phone_number_id_here
